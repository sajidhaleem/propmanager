# ============================================================
# PRODUCTION ENVIRONMENT VARIABLES
# Copy to .env.production.local for local production testing
# Set ALL of these in your Netlify / hosting dashboard
# ============================================================

# ── Database (Neon recommended) ──────────────────────────────
# Get from: https://neon.tech → New Project → Connection String
# IMPORTANT: Use the pooled connection string for production!
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/propmanager?sslmode=require&pgbouncer=true&connect_timeout=15"

# Direct URL for Prisma migrations (non-pooled)
DIRECT_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/propmanager?sslmode=require"

# ── Authentication ────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="replace-with-openssl-rand-base64-32-output"
NEXTAUTH_SECRET="replace-with-different-openssl-rand-base64-32-output"

# Your production URL (no trailing slash)
NEXTAUTH_URL="https://propmanager.netlify.app"
NEXT_PUBLIC_APP_URL="https://propmanager.netlify.app"
NEXT_PUBLIC_APP_NAME="PropManager"

# ── App Config ───────────────────────────────────────────────
NODE_ENV="production"
NEXT_TELEMETRY_DISABLED="1"

# ── Email (optional — for booking notifications) ─────────────
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="465"
# SMTP_USER="resend"
# SMTP_PASS="re_xxxxxxxxxxxx"
# SMTP_FROM="noreply@yourdomain.com"

# ── Monitoring (optional) ────────────────────────────────────
# SENTRY_DSN="https://xxx@sentry.io/xxx"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@sentry.io/xxx"

# ── Analytics (optional) ─────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY="phc_xxxx"
# NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
